<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:pageModels="clr-namespace:ElectronicHandyman.App.PageModels"             
             xmlns:models="clr-namespace:ElectronicHandyman.App.Models"
             xmlns:controls="clr-namespace:ElectronicHandyman.App.Pages.Controls"
             xmlns:pullToRefresh="clr-namespace:Syncfusion.Maui.Toolkit.PullToRefresh;assembly=Syncfusion.Maui.Toolkit"
             xmlns:toolkit="http://schemas.microsoft.com/dotnet/2022/maui/toolkit"
             xmlns:maui="clr-namespace:Camera.MAUI;assembly=Camera.MAUI"
             x:Class="ElectronicHandyman.App.Pages.MainPage"
             x:DataType="pageModels:MainPageModel"
             x:Name="OverviewPage"
             Title="{Binding Today}">

    <Grid RowDefinitions="6*, Auto, 3*">
        <!-- Camera + Overlay stacked -->
        <Grid Grid.Row="0">
            <maui:CameraView x:Name="CameraView"
                             WidthRequest="400"
                             HeightRequest="400" />
            <GraphicsView x:Name="OverlayView"
                          InputTransparent="True" />

            <!-- Loading indicator overlaid on camera -->
            <ActivityIndicator x:Name="LoadingIndicator"
                               IsVisible="False"
                               IsRunning="False"
                               HorizontalOptions="Center"
                               VerticalOptions="Center"
                               Color="Gold"
                               HeightRequest="48"
                               WidthRequest="48" />
        </Grid>

        <!-- Identification result display -->
        <Frame x:Name="IdentificationResultFrame"
               Grid.Row="1"
               IsVisible="False"
               Padding="12"
               Margin="10,5"
               CornerRadius="8"
               BorderColor="Gold"
               BackgroundColor="{AppThemeBinding Light=#F5F5DC, Dark=#2D2D1A}">
            <VerticalStackLayout Spacing="4">
                <Label x:Name="ChipNameLabel"
                       FontSize="18"
                       FontAttributes="Bold"
                       TextColor="{AppThemeBinding Light=Black, Dark=White}" />
                <Label x:Name="IdentificationStatusLabel"
                       FontSize="12"
                       TextColor="Gray" />
            </VerticalStackLayout>
        </Frame>

        <!-- Cropped images -->
        <ScrollView Grid.Row="2">
            <HorizontalStackLayout x:Name="CroppedImagesLayout" Spacing="10" Padding="10" />
        </ScrollView>

        <!-- No camera message -->
        <Label x:Name="NoCameraLabel"
               Grid.Row="0"
               Text="No camera found on this device."
               IsVisible="False"
               HorizontalOptions="Center"
               VerticalOptions="Center" />
    </Grid>
</ContentPage>
