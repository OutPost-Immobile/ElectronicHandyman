<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="using:ElectronicHandyman.Avalonia.ViewModels"
             xmlns:controls="using:ElectronicHandyman.Avalonia.Controls"
             mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="450"
             x:Class="ElectronicHandyman.Avalonia.Views.MainView"
             x:DataType="vm:MainViewModel">
  <Design.DataContext>
    <!-- This only sets the DataContext for the previewer in an IDE,
         to set the actual DataContext for runtime, set the DataContext property in code (look at App.axaml.cs) -->
    <vm:MainViewModel />
  </Design.DataContext>

  <Grid RowDefinitions="*,Auto,Auto" Background="Black">
    <Grid>
      <Grid RenderTransformOrigin="50%,50%">
        <Grid.RenderTransform>
          <RotateTransform Angle="{Binding RotationDegrees}" />
        </Grid.RenderTransform>
        <Image Source="{Binding CameraImage}" Stretch="Uniform" />
        <controls:BoundingBoxOverlay Boxes="{Binding BoundingBoxes}"
                                     FrameWidth="{Binding FrameWidth}"
                                     FrameHeight="{Binding FrameHeight}" />
      </Grid>
    </Grid>
    <StackPanel Grid.Row="1" Spacing="4" Margin="8,4">
      <Button Command="{Binding IdentifyChipsCommand}"
              Content="🔍 Identify Chips"
              HorizontalAlignment="Stretch"
              HorizontalContentAlignment="Center"
              FontSize="18"
              Padding="12" />
      <Button Command="{Binding PickAndIdentifyCommand}"
              Content="📷 Pick Photo"
              HorizontalAlignment="Stretch"
              HorizontalContentAlignment="Center"
              FontSize="18"
              Padding="12" />
    </StackPanel>
    <Border Grid.Row="2" Background="#AA000000" Padding="8">
      <TextBlock Text="{Binding StatusText}" Foreground="White" TextWrapping="Wrap" />
    </Border>
  </Grid>
</UserControl>
