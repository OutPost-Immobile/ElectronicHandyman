<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="using:ElectronicHandyman.Avalonia.ViewModels"
             mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="450"
             x:Class="ElectronicHandyman.Avalonia.Views.ProcessingView"
             x:DataType="vm:ProcessingViewModel">
  <Design.DataContext>
    <vm:ProcessingViewModel />
  </Design.DataContext>

  <Grid RowDefinitions="*,Auto" Background="Black">
    <Image Source="{Binding PreviewImage}" Stretch="Uniform" Opacity="0.5"/>
    
    <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" Spacing="16">
      <ProgressBar IsIndeterminate="True" Width="200" Height="20" />
      <TextBlock Text="{Binding StatusText}" Foreground="White" FontSize="20" HorizontalAlignment="Center" />
    </StackPanel>

    <Button Grid.Row="1" Command="{Binding CancelCommand}" Content="Cancel" Margin="16" HorizontalAlignment="Center" />
  </Grid>
</UserControl>
