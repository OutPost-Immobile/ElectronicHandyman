{
  "ConnectionStrings": {
    "Database": ""
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "Serilog": {
    "Using": ["Serilog.Sinks.Console"],
    "MinimumLevel": "Debug",
    "WriteTo": [
      {
        "Name": "Console"
      }
    ],
    "Enrich": ["FromLogContext", "WithMachineName"],
    "Properties": {
      "ApplicationName": "DeBagger"
    }
  },
  "Source": {
    "Items": [
      {
        "Name": "Arduino",
        "Url": "https://docs.arduino.cc"
      },
      {
        "Name": "PlatformIO",
        "Url": "https://docs.platformio.org/en/latest/boards/"
      }
    ]
  },
  "AllowedHosts": "*"
}
